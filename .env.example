# ════════════════════════════════════════
# TokenLaunchKit Configuration
# ════════════════════════════════════════

# ── Wallet ───────────────────────────────
# Your Solana wallet private key (base58 encoded)
# Generate: solana-keygen new --outfile wallet.json
PRIVATE_KEY=your_base58_private_key_here

# ── OpenAI (for AI image + description) ──
OPENAI_API_KEY=sk-...

# ── IPFS: Pinata ─────────────────────────
# Get your JWT at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=eyJ...

# ── IPFS: nft.storage (fallback) ─────────
NFT_STORAGE_API_KEY=your_nft_storage_key

# ── Solana RPC ───────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── PumpFun ──────────────────────────────
# PumpPortal API key (optional — needed for lightning API)
PUMPPORTAL_API_KEY=your_pumpportal_api_key

# Use pump.fun's native IPFS instead of Pinata
USE_PUMPFUN_IPFS=false

# ── Defaults ─────────────────────────────
DEFAULT_SLIPPAGE=10
DEFAULT_PRIORITY_FEE=0.0005
DEFAULT_INITIAL_BUY_SOL=0
IMAGE_STYLE=vibrant

# ── Output ───────────────────────────────
OUTPUT_DIR=./output
LOG_LEVEL=INFO
